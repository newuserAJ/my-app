# =============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and fill in your actual values
# =============================================================================

# Node Environment (development, production, test, staging)
NODE_ENV=development

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=8080
HOST=localhost

# =============================================================================
# SUPABASE CONFIGURATION (REQUIRED)
# Get these from your Supabase project dashboard
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# =============================================================================
# JWT CONFIGURATION (REQUIRED)
# Generate a secure random string (at least 32 characters)
# =============================================================================
JWT_SECRET=your_super_secure_jwt_secret_key_at_least_32_chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# DATABASE CONFIGURATION (OPTIONAL)
# For direct PostgreSQL connections if not using Supabase client
# =============================================================================
DATABASE_URL=postgresql://username:password@localhost:5432/database_name
DATABASE_POOL_SIZE=10

# =============================================================================
# REDIS CONFIGURATION (OPTIONAL)
# For caching and session storage
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password

# =============================================================================
# EMAIL CONFIGURATION (OPTIONAL)
# For sending emails (notifications, password resets, etc.)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@yourapp.com

# =============================================================================
# AWS CONFIGURATION (OPTIONAL)
# For file uploads and storage
# =============================================================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# =============================================================================
# RATE LIMITING CONFIGURATION
# =============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# =============================================================================
# SECURITY CONFIGURATION (OPTIONAL BUT RECOMMENDED)
# Generate secure random strings for these
# =============================================================================
ENCRYPTION_KEY=your_32_char_encryption_key_here
SESSION_SECRET=your_32_char_session_secret_here

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=false
ENABLE_PASSWORD_RESET=true
ENABLE_RATE_LIMITING=true
ENABLE_CORS=true

# =============================================================================
# MONITORING AND ANALYTICS (OPTIONAL)
# =============================================================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# =============================================================================
# EXTERNAL SERVICE API KEYS (OPTIONAL)
# =============================================================================
OPENAI_API_KEY=sk-your-openai-api-key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# =============================================================================
# SOCIAL AUTHENTICATION (OPTIONAL)
# Get these from Google/GitHub OAuth app settings
# =============================================================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# =============================================================================
# DEVELOPMENT/TESTING OVERRIDES
# =============================================================================
# These can override production settings in development
# DEV_DATABASE_URL=postgresql://dev_user:dev_pass@localhost:5432/dev_db
# DEV_REDIS_URL=redis://localhost:6380
# TEST_DATABASE_URL=postgresql://test_user:test_pass@localhost:5432/test_db